    "The %@ hook will be removed from the list. Nothing is written to disk until you save, and Discard still undoes this.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El hook %@ se eliminará de la lista. No se escribe nada en el disco hasta que guardes, y Descartar aún puede deshacer esto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ フックがリストから削除されます。保存するまでディスクには何も書き込まれず、「破棄」でこの操作を取り消せます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 훅이 목록에서 제거됩니다. 저장하기 전까지 디스크에는 아무것도 기록되지 않으며, 되돌리기로 취소할 수 있어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 钩子将从列表中移除。在你保存之前不会写入磁盘,且“放弃更改”仍可撤销此操作。"
          }
        }
      }
    },
    "The `claude` CLI wasn't found in the usual locations.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontró la CLI `claude` en las ubicaciones habituales."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通常の場所に `claude` CLI が見つかりませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일반적인 위치에서 `claude` CLI를 찾을 수 없었어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在常见位置未找到 `claude` CLI。"
          }
        }
      }
    },
    "The fix came back empty — nothing was changed.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La corrección llegó vacía — no se cambió nada."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "修正が空で返されたため、何も変更されませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수정안이 비어 있어 아무것도 변경하지 않았습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "返回的修复为空 — 未做任何更改。"
          }
        }
      }
    },
    "The model didn't return a usable list. Raw reply:\n%@": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modelo no devolvió una lista utilizable. Respuesta sin procesar:\n%@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "モデルが有効なリストを返しませんでした。生の応答:\n%@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모델이 사용 가능한 목록을 반환하지 않았어요. 원본 응답:\n%@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模型未返回可用的列表。原始回复:\n%@"
          }
        }
      }
    },
    "The open editor has unsaved changes. Switching sections closes it and loses them.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El editor abierto tiene cambios sin guardar. Cambiar de sección lo cierra y los pierde."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "開いているエディタに未保存の変更があります。セクションを切り替えるとエディタが閉じ、変更は失われます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "열려 있는 편집기에 저장하지 않은 변경 사항이 있습니다. 섹션을 이동하면 편집기가 닫히고 변경 사항이 사라집니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开的编辑器有未保存的更改。切换栏目会关闭编辑器并丢失这些更改。"
          }
        }
      }
    },
