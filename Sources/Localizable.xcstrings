    "~/.claude.json is not valid JSON — fix it externally or restore a backup.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude.json no es JSON válido — corrígelo externamente o restaura una copia de seguridad."
