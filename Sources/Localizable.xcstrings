          "stringUnit": {
            "state": "translated",
            "value": "外部リポジトリ — 保存すると %@ に書き込まれます（~/.claude の外）。バックアップは引き続き ~/.claude/backups に保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
