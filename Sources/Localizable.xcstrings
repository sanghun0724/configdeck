    "settings.json changed on disk since load. Reload before saving.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json cambió en el disco desde que se cargó. Recarga antes de guardar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "読み込み後に settings.json がディスク上で変更されました。保存前に再読み込みしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "불러온 후 settings.json이 디스크에서 변경됐어요. 저장 전에 다시 읽어주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自加载后 settings.json 在磁盘上已发生更改。请在保存前重新加载。"
          }
        }
      }
    },
    "settings.json doesn't exist yet — it will be created on first save.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json aún no existe — se creará al guardar por primera vez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json はまだ存在しません — 最初の保存時に作成されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json이 아직 없습니다 — 처음 저장할 때 생성됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json 尚不存在 — 首次保存时将创建。"
          }
        }
      }
    },
    "settings.json is not valid JSON — fix it externally or restore a backup.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json no es JSON válido — corrígelo externamente o restaura una copia de seguridad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json は有効な JSON ではありません — 外部で修正するかバックアップを復元してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json이 올바른 JSON이 아닙니다 — 외부에서 수정하거나 백업을 복원하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json 不是有效的 JSON — 请在外部修复或恢复备份。"
          }
        }
      }
    },
    "settings.json not found or invalid": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json no encontrado o no válido"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json が見つからないか無効です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "settings.json을 찾을 수 없거나 올바르지 않아요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到 settings.json 或文件无效"
          }
        }
      }
    },
