        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude를 스캔하는 동안 표시되는 짧은 설명 줄"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "扫描 ~/.claude 期间显示的占位简短描述"
          }
        }
      }
    },
