    "A backup is saved to ~/.claude/backups first, so this can be undone. The file at %@ will be removed.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Primero se guarda una copia de seguridad en ~/.claude/backups, así que esto se puede deshacer. Se eliminará el archivo en %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude/backups に先にバックアップが保存されるため、元に戻せます。%@ にあるファイルが削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude/backups에 먼저 백업이 저장되므로 되돌릴 수 있어요. %@ 위치의 파일이 삭제됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统会先在 ~/.claude/backups 中写入备份,因此可以撤销。位于 %@ 的文件将被删除。"
          }
        }
      }
    },
    "A backup is written to ~/.claude/backups first, so this can be undone.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Primero se guarda una copia de seguridad en ~/.claude/backups, así que esto se puede deshacer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude/backups に先にバックアップが書き込まれるため、元に戻せます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude/backups에 먼저 백업이 저장되므로 되돌릴 수 있어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统会先在 ~/.claude/backups 中写入备份,因此可以撤销此操作。"
          }
        }
      }
    },
    "A short description line standing in while scanning ~/.claude": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una breve línea de descripción como marcador mientras se escanea ~/.claude"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude をスキャンする間表示される簡単な説明文"
