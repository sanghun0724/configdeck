    },
    "~/.claude.json is written by Claude Code at runtime. If it changes while editing, Save is blocked (use Reload). Other keys are preserved.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Claude Code escribe ~/.claude.json en tiempo de ejecución. Si cambia mientras editas, Guardar se bloquea (usa Recargar). Las demás claves se conservan."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude.json は Claude Code が実行時に書き込むファイルです。編集中に変更された場合、保存はブロックされます（再読み込みを使用）。他のキーは保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude.json은 Claude Code가 런타임에 기록하는 파일입니다. 편집 중 변경되면 저장이 차단됩니다(다시 읽기 사용). 다른 키는 보존됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude.json 由 Claude Code 在运行时写入。若在编辑时发生更改，保存将被阻止（请使用重新加载）。其他键会被保留。"
          }
        }
      }
    },
    "~/.claude.json not found or invalid": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude.json no encontrado o no válido"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude.json が見つからないか無効です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "~/.claude.json을 찾을 수 없거나 올바르지 않아요"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未找到 ~/.claude.json 或文件无效"
          }
        }
      }
    },
    "“%@” will be removed from the list. Nothing is written to disk until you save, and Discard still undoes this.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” se eliminará de la lista. No se escribe nada en el disco hasta que guardes, y Descartar aún puede deshacer esto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」がリストから削除されます。保存するまでディスクには何も書き込まれず、「破棄」でこの操作を取り消せます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”이(가) 목록에서 제거됩니다. 저장하기 전까지 디스크에는 아무것도 기록되지 않으며, 되돌리기로 취소할 수 있어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@”将从列表中移除。在你保存之前不会写入磁盘,且“放弃更改”仍可撤销此操作。"
          }
        }
      }
    },
    "⋯ %lld unchanged lines": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "⋯ %lld líneas sin cambios"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⋯ 変更なし %lld 行"
