    "Looked in /opt/homebrew/bin, /usr/local/bin, ~/.local/bin and ~/.claude/local. Install Claude Code or symlink `claude` into one of those.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se buscó en /opt/homebrew/bin, /usr/local/bin, ~/.local/bin y ~/.claude/local. Instala Claude Code o crea un enlace simbólico de `claude` en uno de esos directorios."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "/opt/homebrew/bin、/usr/local/bin、~/.local/bin、~/.claude/local を確認しました。Claude Code をインストールするか、`claude` をいずれかにシンボリックリンクしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "/opt/homebrew/bin, /usr/local/bin, ~/.local/bin, ~/.claude/local에서 찾아봤어요. Claude Code를 설치하거나 `claude`를 그중 한 곳에 심볼릭 링크하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已在 /opt/homebrew/bin、/usr/local/bin、~/.local/bin 和 ~/.claude/local 中查找。请安装 Claude Code,或将 `claude` 软链接到其中一个目录。"
          }
        }
      }
